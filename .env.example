# Environment variables for Flask Chat App
# Copy this file to .env and fill in your API keys

# OpenAI API Key (required)
OPENAI_API_KEY=your-openai-api-key-here

# LangSmith API Key (required for feedback tracking)
LANGSMITH_API_KEY=your-langsmith-api-key-here

# LangSmith EU region endpoint
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com

# LangSmith Project Name (optional, defaults to 'flask-chat-feedback')
LANGSMITH_PROJECT=flask-chat-feedback
